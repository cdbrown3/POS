<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaUI.CustomerLoginView"
        >
    <!-- Main grid that everything will fill -->
    <Grid>
		<Grid.Background>
			<ImageBrush Source="avares://AvaloniaUI/Resources/Images/LoginBackdrop.png"
                        Stretch="UniformToFill">
            </ImageBrush>
        </Grid.Background>
        <!-- Put content zone in a view box so that it stretches uniformly and always stays a square-->
        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
			<Border Margin="30"
                    Height="400"
                    Width="400"
                    Background="Transparent">
			    <ContentControl x:Name="MainContent"></ContentControl>
            </Border>
        </Viewbox>
    </Grid>
</Window>
